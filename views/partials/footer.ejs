          <li><a href="/courses#ntse"><i class="fas fa-angle-right"></i> NTSE Coaching</a></li>
          <li><a href="/courses#olympiad"><i class="fas fa-angle-right"></i> Olympiad Training</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="footer-col">
        <h4>Contact Info</h4>
        <ul class="footer-contact">
          <li><i class="fas fa-map-marker-alt"></i> Your Institute Address, City, State - PINCODE</li>
          <li><i class="fas fa-phone"></i> <a href="tel:+919896913009">+91 98969 13009</a></li>
          <li><i class="fas fa-envelope"></i> <a href="mailto:info@garudclasses.com">info@garudclasses.com</a></li>
          <li><i class="fas fa-globe"></i> <a href="https://www.garudclasses.com">www.garudclasses.com</a></li>
        </ul>
        <a href="https://wa.me/919896913009" class="whatsapp-btn" target="_blank" rel="noopener">
          <i class="fab fa-whatsapp"></i> Chat on WhatsApp
        </a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; <%= new Date().getFullYear() %> Garud Classes. All Rights Reserved.</p>
      <p><a href="/privacy-policy">Privacy Policy</a> | Designed with <i class="fas fa-heart" style="color:#e74c3c"></i> for academic excellence.</p>
