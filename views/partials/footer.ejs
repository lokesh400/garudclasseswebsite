<!-- ── Chatbot Widget ──────────────────────────────────────── -->
<link rel="stylesheet" href="/css/chatbot.css">

<!-- Blur overlay (shown behind chat window) -->
<div id="chatbot-overlay"></div>

<!-- Toggle Button -->
<button id="chatbot-toggle" aria-label="Open chat assistant">
  <span class="chat-open-icon"><i class="fas fa-comments"></i></span>
  <span class="chat-close-icon"><i class="fas fa-times"></i></span>
  <span id="chatbot-badge"></span>
</button>

<!-- Chat Window -->
<div id="chatbot-window" role="dialog" aria-label="Garud Classes Chat Assistant">
  <!-- Header -->
  <div id="chatbot-header">
    <div class="chatbot-avatar">🦅</div>
    <div class="chatbot-header-info">
      <h4>Garud Assistant</h4>
      <span><span class="online-dot"></span> Online – here to help</span>
    </div>
    <button id="chatbot-minimize" aria-label="Minimize chat"><i class="fas fa-minus"></i></button>
  </div>

  <!-- Quick Suggestions -->
  <div id="chatbot-suggestions">
    <button class="suggestion-btn" data-msg="What courses do you offer?">📚 Courses</button>
    <button class="suggestion-btn" data-msg="How to take admission?">✅ Admission</button>
    <button class="suggestion-btn" data-msg="What are the fees?">💰 Fees</button>
    <button class="suggestion-btn" data-msg="What are the batch timings?">🕐 Timings</button>
    <button class="suggestion-btn" data-msg="Contact details">📞 Contact</button>
  </div>

  <!-- Messages -->
  <div id="chatbot-messages"></div>

  <!-- Input -->
  <div id="chatbot-input-area">
    <textarea id="chatbot-input" placeholder="Type your message..." rows="1" maxlength="500"></textarea>
    <button id="chatbot-send" aria-label="Send message"><i class="fas fa-paper-plane"></i></button>
  </div>

  <div id="chatbot-footer">Garud Classes Virtual Assistant</div>
</div>

<script src="/js/chatbot.js"></script>
<!-- ── End Chatbot Widget ─────────────────────────────────── -->

<script src="/js/main.js"></script>
</body>
</html>
