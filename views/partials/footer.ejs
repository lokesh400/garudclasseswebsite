            <li><a href="/blog"><i class="fas fa-angle-right"></i> Blog</a></li>
            <li><a href="/contact"><i class="fas fa-angle-right"></i> Contact Us</a></li>
            <li><a href="/privacy-policy"><i class="fas fa-angle-right"></i> Privacy Policy</a></li>
          <% } %>
        </ul>
      </div>

      <!-- Courses Links -->
      <div class="footer-col">
        <h4>Our Courses</h4>
        <ul>
          <li><a href="/courses#jee"><i class="fas fa-angle-right"></i> JEE Main & Advanced</a></li>
