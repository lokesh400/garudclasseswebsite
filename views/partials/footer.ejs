<footer class="footer">
  <div class="footer-top">
    <div class="container footer-grid">
      <!-- Brand -->
      <div class="footer-col footer-brand">
        <div class="footer-logo">
          <img src="/img/logo.png" alt="Garud Classes Logo" class="logo-img logo-img-footer">
          <div class="logo-text">
            <span class="logo-main">GARUD</span>
            <span class="logo-sub">CLASSES</span>
          </div>
        </div>
        <p>Empowering students to soar to new heights with quality education, expert guidance, and proven results. Your success is our mission.</p>
        <div class="footer-social">
