<%- include('partials/head') %>
<%- include('partials/navbar') %>

<section class="page-banner">
  <div class="container">
    <h1><%= blog.title %></h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb"><li><a href="/">Home</a></li><li><a href="/blog">Blog</a></li><li class="active">Article</li></ol>
    </nav>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="blog-detail-grid">
      <article class="blog-article">
        <% if (blog.image) { %><img src="<%= blog.image %>" alt="<%= blog.title %>" class="blog-article-img" loading="lazy"><% } %>
        <div class="blog-article-meta">
          <span><i class="fas fa-calendar"></i> <%= blog.publishedAt?.toLocaleDateString('en-IN', { day:'2-digit', month:'long', year:'numeric' }) %></span>
          <span><i class="fas fa-folder"></i> <%= blog.category %></span>
          <% if (blog.tags && blog.tags.length > 0) { %>
          <span><i class="fas fa-tags"></i> <%= blog.tags.join(', ') %></span>
          <% } %>
        </div>
        <div class="blog-article-content"><%- blog.content %></div>
        <div class="blog-share">
          <strong>Share this article:</strong>
          <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(siteUrl + '/blog/' + blog.slug) %>" target="_blank" rel="noopener" class="share-btn share-fb"><i class="fab fa-facebook-f"></i></a>
          <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(siteUrl + '/blog/' + blog.slug) %>&text=<%= encodeURIComponent(blog.title) %>" target="_blank" rel="noopener" class="share-btn share-tw"><i class="fab fa-twitter"></i></a>
          <a href="https://wa.me/?text=<%= encodeURIComponent(blog.title + ' - ' + siteUrl + '/blog/' + blog.slug) %>" target="_blank" rel="noopener" class="share-btn share-wa"><i class="fab fa-whatsapp"></i></a>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="blog-sidebar">
        <div class="sidebar-widget">
          <h4>Related Articles</h4>
          <% if (related && related.length > 0) { %>
          <% related.forEach(r => { %>
          <div class="related-post">
            <% if (r.image) { %><img src="<%= r.image %>" alt="<%= r.title %>" loading="lazy"><% } %>
            <div>
              <a href="/blog/<%= r.slug %>"><%= r.title %></a>
              <small><%= r.publishedAt?.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %></small>
            </div>
          </div>
          <% }) %>
          <% } else { %><p>No related posts.</p><% } %>
        </div>
        <div class="sidebar-widget">
          <h4>Quick Links</h4>
          <ul class="sidebar-links">
            <li><a href="/courses"><i class="fas fa-angle-right"></i> Our Courses</a></li>
            <li><a href="/results"><i class="fas fa-angle-right"></i> Student Results</a></li>
            <li><a href="/faculty"><i class="fas fa-angle-right"></i> Our Faculty</a></li>
            <li><a href="/contact"><i class="fas fa-angle-right"></i> Contact Us</a></li>
          </ul>
        </div>
        <div class="sidebar-cta">
          <h4>Enroll Today!</h4>
          <p>Join thousands of successful students at Garud Classes.</p>
          <a href="/contact" class="btn btn-primary btn-block">Enquire Now</a>
        </div>
      </aside>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
