<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- Page Banner -->
<section class="page-banner">
  <div class="container">
    <h1>About <span>Garud Classes</span></h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li class="active">About Us</li>
      </ol>
    </nav>
  </div>
</section>

<%- include('partials/flash') %>

<!-- About Content -->
<section class="section">
  <div class="container">
    <div class="about-grid">
      <div class="about-img-wrap">
        <img src="/img/about-institute.jpg" alt="Garud Classes Institute" class="about-img" loading="lazy">
        <div class="about-experience-badge">
          <strong>15+</strong>
          <span>Years of Excellence</span>
        </div>
      </div>
      <div class="about-content">
        <div class="section-badge">Our Story</div>
        <h2 class="section-title">Empowering Students to <span class="text-gradient">Soar High</span></h2>
        <p>Garud Classes was founded with a single, powerful vision: to provide world-class coaching to every deserving student, regardless of their background. Over the past 15+ years, we have grown to become one of the most trusted names in competitive exam coaching.</p>
        <p>Our institute has produced hundreds of IITians, doctors, and board toppers. We believe in a holistic approach to education — building not just academic excellence but also mental strength, discipline, and character.</p>
        <div class="about-features">
          <div class="about-feature"><i class="fas fa-check-circle"></i> <span>Expert IITian & AIIMS Faculty</span></div>
          <div class="about-feature"><i class="fas fa-check-circle"></i> <span>State-of-the-Art Classrooms</span></div>
          <div class="about-feature"><i class="fas fa-check-circle"></i> <span>Comprehensive Study Material</span></div>
          <div class="about-feature"><i class="fas fa-check-circle"></i> <span>Regular Mock Tests & Analysis</span></div>
          <div class="about-feature"><i class="fas fa-check-circle"></i> <span>Personal Mentoring Program</span></div>
          <div class="about-feature"><i class="fas fa-check-circle"></i> <span>Parent-Teacher Communication</span></div>
        </div>
        <a href="/contact" class="btn btn-primary">Get Admission <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </div>
</section>

<!-- Mission, Vision, Values -->
<section class="section mvv-section">
  <div class="container">
    <div class="mvv-grid">
      <div class="mvv-card">
        <div class="mvv-icon"><i class="fas fa-bullseye"></i></div>
        <h3>Our Mission</h3>
        <p>To provide affordable, high-quality coaching that empowers every student to achieve their academic dreams and secure admission to premier institutions like IITs, NITs, and AIIMS.</p>
      </div>
      <div class="mvv-card">
        <div class="mvv-icon"><i class="fas fa-eye"></i></div>
        <h3>Our Vision</h3>
        <p>To be the most student-centric coaching institute in the country — where every student is nurtured, guided, and equipped to face India's most competitive examinations with confidence.</p>
      </div>
      <div class="mvv-card">
        <div class="mvv-icon"><i class="fas fa-heart"></i></div>
        <h3>Our Values</h3>
        <p>Integrity, dedication, excellence, and empathy guide everything we do. We treat every student as a future achiever and give our 100% to help them reach their full potential.</p>
      </div>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="section stats-section-full">
  <div class="container">
    <div class="stats-full-grid">
      <div class="stat-box"><div class="stat-big" data-target="10000">0</div><div class="stat-lbl">Students Coached</div></div>
      <div class="stat-box"><div class="stat-big" data-target="500">0</div><div class="stat-lbl">IIT Selections</div></div>
      <div class="stat-box"><div class="stat-big" data-target="800">0</div><div class="stat-lbl">NEET Qualifiers</div></div>
      <div class="stat-box"><div class="stat-big" data-target="50">0</div><div class="stat-lbl">Expert Faculty</div></div>
      <div class="stat-box"><div class="stat-big" data-target="15">0</div><div class="stat-lbl">Years Experience</div></div>
      <div class="stat-box"><div class="stat-big" data-target="200">0</div><div class="stat-lbl">Board Toppers</div></div>
    </div>
  </div>
</section>

<!-- Infrastructure -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">World-Class Infrastructure</div>
      <h2 class="section-title">Our <span class="text-gradient">Campus</span></h2>
    </div>
    <div class="infra-grid">
      <div class="infra-card"><i class="fas fa-desktop"></i><h4>Smart Classrooms</h4><p>Air-conditioned classrooms with digital boards and projectors for enhanced learning.</p></div>
      <div class="infra-card"><i class="fas fa-flask"></i><h4>Science Labs</h4><p>Fully equipped Physics, Chemistry and Biology labs for hands-on learning.</p></div>
      <div class="infra-card"><i class="fas fa-book"></i><h4>Library</h4><p>Well-stocked library with thousands of books, journals, and study materials.</p></div>
      <div class="infra-card"><i class="fas fa-wifi"></i><h4>Digital Resources</h4><p>Online test portal, recorded lectures, and digital study material accessible 24/7.</p></div>
      <div class="infra-card"><i class="fas fa-shield-alt"></i><h4>Safe Campus</h4><p>CCTV-monitored campus with trained staff to ensure student safety.</p></div>
      <div class="infra-card"><i class="fas fa-utensils"></i><h4>Cafeteria</h4><p>Hygienic and nutritious food options available on campus for students.</p></div>
    </div>
  </div>
</section>

