<%- include('partials/header', { page: 'quicklinks', unreadContacts: 0 }) %>

<div class="admin-page-header">
  <div>
    <h1><i class="fas fa-link"></i> Quick Links</h1>
    <p>Manage the Quick Links shown in the website footer</p>
  </div>
  <a href="/admin/quick-links/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Link</a>
</div>

<% if (quickLinks.length === 0) { %>
  <div class="empty-admin">
    <i class="fas fa-link"></i>
    <p>No quick links yet. <a href="/admin/quick-links/new">Add your first link</a></p>
  </div>
<% } else { %>
<div class="table-responsive">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Category</th>
        <th>Order</th>
        <th>Icon</th>
        <th>Title</th>
        <th>URL</th>
        <th>New Tab</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% quickLinks.forEach(link => { %>
      <tr>
        <td>
          <% if(link.category === 'banner'){ %>
            <span class="badge badge-primary"><i class="fas fa-bullhorn"></i> Banner</span>
          <% } else { %>
            <span class="badge" style="background:#e9ecef;color:#495057;"><i class="fas fa-link"></i> Basic</span>
          <% } %>
        </td>
        <td><span style="font-weight:600;color:#888;"><%= link.order %></span></td>
        <td><i class="<%= link.icon %>"></i></td>
        <td><strong><%= link.title %></strong></td>
        <td>
          <a href="<%= link.url %>" target="_blank" rel="noopener"
             style="color:var(--primary);font-size:0.85rem;word-break:break-all;">
            <%= link.url.length > 50 ? link.url.substring(0,50)+'…' : link.url %>
          </a>
        </td>
        <td>
          <% if(link.openInNewTab){ %>
            <span class="badge badge-primary"><i class="fas fa-external-link-alt"></i> Yes</span>
          <% } else { %>
            <span style="color:#aaa;font-size:0.82rem;">No</span>
          <% } %>
        </td>
        <td>
          <span class="badge <%= link.isActive ? 'badge-success' : 'badge-danger' %>">
            <%= link.isActive ? 'Active' : 'Inactive' %>
          </span>
        </td>
        <td>
          <div class="table-actions">
            <a href="/admin/quick-links/<%= link._id %>/edit" class="btn btn-outline btn-sm">
              <i class="fas fa-edit"></i> Edit
            </a>
            <form action="/admin/quick-links/<%= link._id %>?_method=DELETE" method="POST"
                  onsubmit="return confirm('Delete this link?')" style="display:inline;">
              <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<%- include('partials/footer') %>
