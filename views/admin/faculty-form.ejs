<%- include('partials/header', { page: 'faculty', unreadContacts: 0 }) %>

<div class="admin-page-header">
  <h1><i class="fas fa-chalkboard-teacher"></i> <%= faculty ? 'Edit' : 'Add' %> Faculty</h1>
  <a href="/admin/faculty" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="admin-form-card">
  <form action="<%= faculty ? '/admin/faculty/' + faculty._id + '?_method=PUT' : '/admin/faculty' %>" method="POST" enctype="multipart/form-data">
    <div class="form-grid-2">
      <div class="form-group">
        <label>Full Name *</label>
        <input type="text" name="name" value="<%= faculty ? faculty.name : '' %>" required>
      </div>
      <div class="form-group">
        <label>Designation *</label>
        <input type="text" name="designation" value="<%= faculty ? faculty.designation : '' %>" placeholder="e.g. HOD Physics" required>
      </div>
    </div>
    <div class="form-grid-2">
      <div class="form-group">
        <label>Subject *</label>
        <input type="text" name="subject" value="<%= faculty ? faculty.subject : '' %>" required>
      </div>
      <div class="form-group">
        <label>Experience</label>
        <input type="text" name="experience" value="<%= faculty ? faculty.experience : '' %>" placeholder="e.g. 12+ Years">
      </div>
    </div>
    <div class="form-grid-2">
      <div class="form-group">
        <label>Qualification</label>
        <input type="text" name="qualification" value="<%= faculty ? faculty.qualification : '' %>" placeholder="e.g. B.Tech IIT Delhi">
      </div>
      <div class="form-group">
        <label>Display Order</label>
        <input type="number" name="order" value="<%= faculty ? faculty.order : 0 %>">
      </div>
    </div>
    <div class="form-group">
      <label>About</label>
      <textarea name="about" rows="4"><%= faculty ? faculty.about : '' %></textarea>
    </div>
    <div class="form-group">
      <label>Achievements (one per line)</label>
      <textarea name="achievements" rows="4"><%= faculty ? faculty.achievements?.join('\n') : '' %></textarea>
    </div>
    <div class="form-grid-2">
      <div class="form-group">
        <label>Photo</label>
        <input type="file" name="photo" accept="image/*">
        <% if (faculty && faculty.photo && !faculty.photo.includes('default')) { %>
        <img src="<%= faculty.photo %>" alt="" class="preview-img">
        <% } %>
      </div>
      <div class="form-group">
        <label>Status</label>
        <select name="isActive">
          <option value="true" <%= !faculty || faculty.isActive ? 'selected' : '' %>>Active</option>
          <option value="false" <%= faculty && !faculty.isActive ? 'selected' : '' %>>Inactive</option>
        </select>
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> <%= faculty ? 'Update' : 'Add' %> Faculty</button>
      <a href="/admin/faculty" class="btn btn-outline btn-lg">Cancel</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
