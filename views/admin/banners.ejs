<%- include('partials/header') %>

<div class="admin-page-header">
  <div>
    <h1><i class="fas fa-images"></i> Banners</h1>
    <p>Manage homepage sliding banners</p>
  </div>
  <a href="/admin/banners/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Banner</a>
</div>

<% if (banners.length === 0) { %>
  <div class="empty-admin">
    <i class="fas fa-images"></i>
    <p>No banners yet. <a href="/admin/banners/new">Add your first banner</a></p>
  </div>
<% } else { %>
<div class="table-responsive">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Preview</th>
        <th>Title</th>
        <th>Subtitle</th>
        <th>Button</th>
        <th>Order</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% banners.forEach(b => { %>
      <tr>
        <td><img src="<%= b.image %>" alt="<%= b.title %>" class="table-img" style="width:90px;height:52px;object-fit:cover;border-radius:6px;"></td>
        <td><strong><%= b.title %></strong></td>
        <td><%= b.subtitle || '—' %></td>
        <td><a href="<%= b.buttonLink %>" style="color:var(--primary);font-weight:600;"><%= b.buttonText %></a></td>
        <td><%= b.order %></td>
        <td><span class="badge <%= b.isActive ? 'badge-success' : 'badge-danger' %>"><%= b.isActive ? 'Active' : 'Inactive' %></span></td>
        <td>
          <div class="table-actions">
            <a href="/admin/banners/<%= b._id %>/edit" class="btn btn-outline btn-sm"><i class="fas fa-edit"></i> Edit</a>
            <form action="/admin/banners/<%= b._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this banner?')">
              <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<%- include('partials/footer') %>
