<%- include('partials/header') %>

<div class="admin-page-header">
  <div>
    <h1><i class="fas fa-<%= banner ? 'edit' : 'plus' %>"></i> <%= banner ? 'Edit' : 'Add' %> Banner</h1>
    <p>Banners appear as a full-width image slider on the homepage.</p>
  </div>
  <a href="/admin/banners" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="admin-form-card" style="max-width:560px;">
  <form action="/admin/banners<%= banner ? '/' + banner._id + '?_method=PUT' : '' %>" method="POST" enctype="multipart/form-data">

    <div class="form-group">
      <label><i class="fas fa-image"></i> Banner Image <%= banner ? '' : '*' %></label>
      <input type="file" name="image" id="imageInput" accept="image/*" <%= banner ? '' : 'required' %>>
      <small style="color:var(--text-light);">Recommended: 1400×500 px, JPG/PNG/WEBP. Max 5 MB.</small>
      <% if (banner && banner.image) { %>
        <img id="imgPreview" src="<%= banner.image %>" style="display:block;width:100%;height:120px;object-fit:cover;margin-top:10px;border-radius:8px;border:2px solid var(--border);">
      <% } else { %>
        <img id="imgPreview" style="display:none;width:100%;height:120px;object-fit:cover;margin-top:10px;border-radius:8px;border:2px solid var(--border);">
      <% } %>
    </div>

    <div class="form-grid-2">
      <div class="form-group">
        <label><i class="fas fa-sort-numeric-up"></i> Display Order</label>
        <input type="number" name="order" value="<%= banner ? banner.order : 0 %>" min="0">
      </div>
      <div class="form-group">
        <label><i class="fas fa-toggle-on"></i> Status</label>
        <select name="isActive">
          <option value="true"  <%= (!banner || banner.isActive)  ? 'selected' : '' %>>Active</option>
          <option value="false" <%= (banner && !banner.isActive) ? 'selected' : '' %>>Inactive</option>
        </select>
      </div>
    </div>

    <!-- Title kept as hidden so the model doesn't throw a required error -->
    <input type="hidden" name="title" value="<%= banner ? (banner.title || 'banner') : 'banner' %>">

    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> <%= banner ? 'Update Banner' : 'Add Banner' %></button>
      <a href="/admin/banners" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<script>
  document.getElementById('imageInput').addEventListener('change', function() {
    const preview = document.getElementById('imgPreview');
    if (this.files[0]) { preview.src = URL.createObjectURL(this.files[0]); preview.style.display = 'block'; }
  });
</script>

<%- include('partials/footer') %>
