<%- include('partials/header') %>

<div class="admin-page-header">
  <div>
    <h1><i class="fas fa-<%= banner ? 'edit' : 'plus' %>"></i> <%= banner ? 'Edit' : 'Add' %> Banner</h1>
    <p>Banners appear as a full-width moving slider on the homepage</p>
  </div>
  <a href="/admin/banners" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="admin-form-card">
  <form action="/admin/banners<%= banner ? '/' + banner._id + '?_method=PUT' : '' %>" method="POST" enctype="multipart/form-data">

    <div class="form-grid-2">
      <div class="form-group">
        <label><i class="fas fa-heading"></i> Title *</label>
        <input type="text" name="title" value="<%= banner ? banner.title : '' %>" required placeholder="e.g. Admissions Open 2025-26">
      </div>
      <div class="form-group">
        <label><i class="fas fa-text-height"></i> Subtitle</label>
        <input type="text" name="subtitle" value="<%= banner ? banner.subtitle || '' : '' %>" placeholder="e.g. Enroll now for JEE / NEET batch">
      </div>
    </div>

    <div class="form-grid-2">
      <div class="form-group">
        <label><i class="fas fa-image"></i> Banner Image <%= banner ? '' : '*' %></label>
        <input type="file" name="image" accept="image/*" <%= banner ? '' : 'required' %>>
        <small style="color:var(--text-light);">Recommended: 1400×500 px, JPG/PNG/WEBP. Max 5 MB.</small>
        <% if (banner && banner.image) { %>
          <img src="<%= banner.image %>" class="preview-img" style="width:200px;height:80px;object-fit:cover;margin-top:8px;border-radius:8px;">
        <% } else { %>
          <img class="preview-img" style="display:none;width:200px;height:80px;object-fit:cover;margin-top:8px;border-radius:8px;">
        <% } %>
      </div>
      <div class="form-group">
        <label><i class="fas fa-palette"></i> Overlay Color (fallback)</label>
        <input type="color" name="bgColor" value="<%= banner ? banner.bgColor || '#1d3557' : '#1d3557' %>" style="height:44px;padding:4px 8px;border-radius:8px;border:2px solid var(--border);">
        <small style="color:var(--text-light);">Used as dark overlay tint on the image.</small>
      </div>
    </div>

    <div class="form-grid-2">
      <div class="form-group">
        <label><i class="fas fa-mouse-pointer"></i> Button Text</label>
        <input type="text" name="buttonText" value="<%= banner ? banner.buttonText || '' : 'Learn More' %>" placeholder="e.g. Enroll Now">
      </div>
      <div class="form-group">
        <label><i class="fas fa-link"></i> Button Link</label>
        <input type="text" name="buttonLink" value="<%= banner ? banner.buttonLink || '' : '/courses' %>" placeholder="/courses">
      </div>
    </div>

    <div class="form-grid-2">
      <div class="form-group">
        <label><i class="fas fa-sort-numeric-up"></i> Display Order</label>
        <input type="number" name="order" value="<%= banner ? banner.order : 0 %>" min="0">
      </div>
      <div class="form-group" style="justify-content:flex-end;padding-bottom:14px;">
        <label><i class="fas fa-toggle-on"></i> Status</label>
        <select name="isActive">
          <option value="true"  <%= (!banner || banner.isActive)  ? 'selected' : '' %>>Active</option>
          <option value="false" <%= (banner && !banner.isActive) ? 'selected' : '' %>>Inactive</option>
        </select>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> <%= banner ? 'Update Banner' : 'Add Banner' %></button>
      <a href="/admin/banners" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
