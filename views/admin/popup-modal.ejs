<%- include('partials/header') %>

<div class="admin-page-header">
  <div>
    <h1><i class="fas fa-window-restore"></i> Popup Modal Settings</h1>
    <p>This popup is shown to every visitor when the homepage loads. Set <strong>Status</strong> to <em>Inactive</em> to hide it.</p>
  </div>
</div>

<div class="admin-form-card" style="max-width:600px;">
  <form action="/admin/popup-modal" method="POST" enctype="multipart/form-data">

    <!-- Image -->
    <div class="form-group">
      <label><i class="fas fa-image"></i> Popup Image</label>
      <input type="file" name="image" id="imageInput" accept="image/*">
      <small style="color:var(--text-light);">Recommended: 600×400 px, JPG/PNG/WEBP. Max 5 MB. Leave blank to keep current image.</small>
      <% if (popup && popup.image) { %>
        <img id="imgPreview" src="<%= popup.image %>" style="display:block;width:100%;max-height:240px;object-fit:cover;margin-top:10px;border-radius:8px;border:2px solid var(--border);">
      <% } else { %>
        <img id="imgPreview" style="display:none;width:100%;max-height:240px;object-fit:cover;margin-top:10px;border-radius:8px;border:2px solid var(--border);">
      <% } %>
    </div>

    <!-- Status -->
    <div class="form-group">
      <label><i class="fas fa-toggle-on"></i> Status</label>
      <select name="isActive">
        <option value="true"  <%= (!popup || popup.isActive)  ? 'selected' : '' %>>Active (show on homepage)</option>
        <option value="false" <%= (popup && !popup.isActive) ? 'selected' : '' %>>Inactive (hidden)</option>
      </select>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Changes</button>
    </div>
  </form>
</div>

<script>
  document.getElementById('imageInput').addEventListener('change', function () {
    const preview = document.getElementById('imgPreview');
    if (this.files[0]) { preview.src = URL.createObjectURL(this.files[0]); preview.style.display = 'block'; }
  });
</script>

<%- include('partials/footer') %>
