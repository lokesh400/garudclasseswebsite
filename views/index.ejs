<%- include('partials/head') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<!-- ══════════════════════════════════════════════════════════
     HERO SECTION
══════════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-particles" id="particles"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-text">
      <div class="hero-badge"><i class="fas fa-award"></i> Trusted by 10,000+ Students</div>
      <h1 class="hero-title">
        Achieve Your <span class="text-gradient">Dream Rank</span><br>
        With Garud Classes
      </h1>
      <p class="hero-desc">
        Premier coaching for <strong>JEE Main & Advanced</strong>, <strong>NEET UG</strong>, 
        Foundation, Board Exams, NTSE & Olympiads. Expert faculty, proven methodology, outstanding results.
      </p>
      <div class="hero-btns">
        <a href="/courses" class="btn btn-primary">Explore Courses <i class="fas fa-arrow-right"></i></a>
        <a href="/results" class="btn btn-outline">View Results <i class="fas fa-trophy"></i></a>
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-num" data-target="10000">0</div>
          <div class="stat-label">Students Coached</div>
        </div>
        <div class="stat-item">
          <div class="stat-num" data-target="15">0</div>
          <div class="stat-label">Years Experience</div>
        </div>
        <div class="stat-item">
          <div class="stat-num" data-target="500">0</div>
          <div class="stat-label">IIT / NIT Selections</div>
        </div>
        <div class="stat-item">
          <div class="stat-num" data-target="800">0</div>
          <div class="stat-label">NEET Selections</div>
        </div>
      </div>
    </div>
    <div class="hero-image">
      <div class="hero-card-group">
        <div class="floating-card card-1">
          <i class="fas fa-trophy"></i>
          <div><strong>AIR 1</strong><span>JEE Advanced</span></div>
        </div>
        <div class="floating-card card-2">
          <i class="fas fa-star"></i>
          <div><strong>720/720</strong><span>NEET Score</span></div>
        </div>
        <div class="floating-card card-3">
          <i class="fas fa-medal"></i>
          <div><strong>State Topper</strong><span>Board Exams</span></div>
        </div>
        <div class="hero-img-wrap">
          <img src="/img/hero-students.svg" alt="Students studying at Garud Classes" width="500" height="500">
        </div>
      </div>
    </div>
  </div>
  <div class="hero-wave">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     MARQUEE – ACHIEVEMENTS
══════════════════════════════════════════════════════════ -->
<div class="marquee-bar">
  <div class="marquee-track">
    <span><i class="fas fa-trophy"></i> 500+ IIT Selections</span>
    <span><i class="fas fa-heartbeat"></i> 800+ NEET Qualifiers</span>
    <span><i class="fas fa-star"></i> 15+ Years of Excellence</span>
    <span><i class="fas fa-medal"></i> State Board Toppers</span>
    <span><i class="fas fa-users"></i> 10,000+ Students Trained</span>
    <span><i class="fas fa-award"></i> Best Coaching Institute Award</span>
    <span><i class="fas fa-trophy"></i> 500+ IIT Selections</span>
    <span><i class="fas fa-heartbeat"></i> 800+ NEET Qualifiers</span>
    <span><i class="fas fa-star"></i> 15+ Years of Excellence</span>
    <span><i class="fas fa-medal"></i> State Board Toppers</span>
    <span><i class="fas fa-users"></i> 10,000+ Students Trained</span>
    <span><i class="fas fa-award"></i> Best Coaching Institute Award</span>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════
     BANNER SLIDER
══════════════════════════════════════════════════════════ -->
<% const activeBanners = (typeof banners !== 'undefined' && banners.length > 0) ? banners : [
  { title: 'Admissions Open 2025–26', subtitle: 'JEE Main & Advanced | NEET-UG | Foundation Batches', image: '/img/hero-students.svg', buttonText: 'Enroll Now', buttonLink: '/contact', bgColor: '#1d3557' },
  { title: 'Board Exam Special Batch', subtitle: 'Score 90%+ with our expert faculty — limited seats', image: '/img/hero-students.svg', buttonText: 'View Courses', buttonLink: '/courses', bgColor: '#0d2137' },
  { title: 'NEET 2025 Crash Course', subtitle: 'Intensive 3-month program starting April 2025', image: '/img/hero-students.svg', buttonText: 'Know More', buttonLink: '/courses', bgColor: '#1a0a2e' }
]; %>

<section class="banner-slider-section">
  <div class="banner-slider" id="bannerSlider">
    <div class="banner-track" id="bannerTrack">
      <% activeBanners.forEach((b, i) => { %>
      <div class="banner-slide" style="background-color:<%= b.bgColor || '#1d3557' %>;">
        <div class="banner-slide-img" style="background-image:url('<%= b.image %>')"></div>

      </div>
      <% }) %>
    </div>

    <!-- Controls -->
    <button class="banner-prev" id="bannerPrev" aria-label="Previous"><i class="fas fa-chevron-left"></i></button>
    <button class="banner-next" id="bannerNext" aria-label="Next"><i class="fas fa-chevron-right"></i></button>

    <!-- Dots -->
    <div class="banner-dots" id="bannerDots">
      <% activeBanners.forEach((b, i) => { %>
      <span class="banner-dot <%= i === 0 ? 'active' : '' %>" data-index="<%= i %>"></span>
      <% }) %>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     COURSES SECTION
══════════════════════════════════════════════════════════ -->
<section class="section courses-section" id="courses">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">Our Programs</div>
      <h2 class="section-title">Courses We <span class="text-gradient">Offer</span></h2>
      <p class="section-desc">Comprehensive coaching programs designed by expert faculty to help you achieve your goals.</p>
    </div>
    <% if (courses && courses.length > 0) { %>
    <div class="courses-grid">
      <% courses.forEach((course, i) => { %>
      <div class="course-card" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
        <div class="course-icon">
          <i class="<%= course.icon || 'fas fa-book' %>"></i>
        </div>
        <div class="course-body">
          <span class="course-tag"><%= course.category %></span>
          <h3><%= course.name %></h3>
          <p><%= course.shortDesc || course.description?.substring(0,100) + '...' %></p>
          <% if (course.features && course.features.length > 0) { %>
          <ul class="course-features">
            <% course.features.slice(0,3).forEach(f => { %>
            <li><i class="fas fa-check-circle"></i> <%= f %></li>
            <% }) %>
          </ul>
          <% } %>
        </div>
        <div class="course-footer">
          <% if (course.duration) { %><span><i class="fas fa-clock"></i> <%= course.duration %></span><% } %>
          <a href="/courses/<%= course.slug %>" class="btn btn-sm btn-primary">Know More</a>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <!-- Default course cards when DB is empty -->
    <div class="courses-grid">
      <div class="course-card">
        <div class="course-icon course-icon-jee"><i class="fas fa-atom"></i></div>
        <div class="course-body">
          <span class="course-tag">JEE</span>
          <h3>JEE Main & Advanced</h3>
          <p>Comprehensive preparation for IIT-JEE with Physics, Chemistry & Mathematics from expert IITian faculty.</p>
          <ul class="course-features">
            <li><i class="fas fa-check-circle"></i> Daily Practice Problems</li>
            <li><i class="fas fa-check-circle"></i> Mock Test Series</li>
            <li><i class="fas fa-check-circle"></i> Doubt Clearing Sessions</li>
          </ul>
        </div>
        <div class="course-footer">
          <span><i class="fas fa-clock"></i> 2 Years</span>
          <a href="/courses" class="btn btn-sm btn-primary">Know More</a>
        </div>
      </div>
      <div class="course-card">
        <div class="course-icon course-icon-neet"><i class="fas fa-heartbeat"></i></div>
        <div class="course-body">
          <span class="course-tag">NEET</span>
          <h3>NEET UG</h3>
          <p>Complete NEET preparation covering Physics, Chemistry & Biology with experienced medical faculty.</p>
          <ul class="course-features">
            <li><i class="fas fa-check-circle"></i> NCERT-Based Teaching</li>
            <li><i class="fas fa-check-circle"></i> Weekly Mock Tests</li>
            <li><i class="fas fa-check-circle"></i> Biology Special Batches</li>
          </ul>
        </div>
        <div class="course-footer">
          <span><i class="fas fa-clock"></i> 2 Years</span>
          <a href="/courses" class="btn btn-sm btn-primary">Know More</a>
        </div>
      </div>
      <div class="course-card">
        <div class="course-icon course-icon-foundation"><i class="fas fa-graduation-cap"></i></div>
        <div class="course-body">
          <span class="course-tag">FOUNDATION</span>
          <h3>Foundation (Class 8-10)</h3>
          <p>Build a strong foundation from early classes to prepare for competitive exams and board exams.</p>
          <ul class="course-features">
            <li><i class="fas fa-check-circle"></i> Concept-based Learning</li>
            <li><i class="fas fa-check-circle"></i> NTSE Preparation</li>
            <li><i class="fas fa-check-circle"></i> Olympiad Training</li>
          </ul>
        </div>
        <div class="course-footer">
          <span><i class="fas fa-clock"></i> 1-3 Years</span>
          <a href="/courses" class="btn btn-sm btn-primary">Know More</a>
        </div>
      </div>
      <div class="course-card">
        <div class="course-icon course-icon-board"><i class="fas fa-book-open"></i></div>
        <div class="course-body">
          <span class="course-tag">BOARD</span>
          <h3>Board Exam Preparation</h3>
          <p>Score 95%+ in CBSE/State Board exams with structured study material and regular tests.</p>
          <ul class="course-features">
            <li><i class="fas fa-check-circle"></i> Sample Papers</li>
            <li><i class="fas fa-check-circle"></i> Previous Year Questions</li>
            <li><i class="fas fa-check-circle"></i> One-on-One Mentoring</li>
          </ul>
        </div>
        <div class="course-footer">
          <span><i class="fas fa-clock"></i> 1 Year</span>
          <a href="/courses" class="btn btn-sm btn-primary">Know More</a>
        </div>
      </div>
    </div>
    <% } %>
    <div class="section-cta">
      <a href="/courses" class="btn btn-primary btn-lg">View All Courses <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     WHY CHOOSE US
══════════════════════════════════════════════════════════ -->
<section class="section why-section">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">Why Garud Classes?</div>
      <h2 class="section-title">The Garud <span class="text-gradient">Advantage</span></h2>
      <p class="section-desc">We don't just teach — we transform students into toppers.</p>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon"><i class="fas fa-chalkboard-teacher"></i></div>
        <h3>Expert Faculty</h3>
        <p>IITian, NIT & top university alumni with 10+ years of coaching experience.</p>
