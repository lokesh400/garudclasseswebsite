<!-- ══════════════════════════════════════════════════════════
     TOP RESULTS
══════════════════════════════════════════════════════════ -->
<section class="section results-section">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">Hall of Fame</div>
      <h2 class="section-title">Our Star <span class="text-gradient">Performers</span></h2>
      <p class="section-desc">Celebrating the exceptional achievements of our students across all competitive exams.</p>
    </div>
    <% if (topResults && topResults.length > 0) { %>
    <div class="results-grid">
      <% topResults.slice(0,6).forEach((r, i) => { %>
      <div class="result-card" data-aos="zoom-in" data-aos-delay="<%= i * 80 %>">
        <div class="result-rank-badge"><% if(r.rank) { %><%= r.rank %><% } else { %>Topper<% } %></div>
        <img src="<%= r.photo || '/img/default-student.png' %>" alt="<%= r.studentName %>" class="result-photo" loading="lazy">
        <div class="result-info">
          <h4><%= r.studentName %></h4>
          <p class="result-exam"><%= r.exam %></p>
          <% if (r.score) { %><p class="result-score"><i class="fas fa-star"></i> <%= r.score %></p><% } %>
          <% if (r.percentile) { %><p class="result-percentile"><i class="fas fa-percent"></i> <%= r.percentile %> Percentile</p><% } %>
        </div>
        <div class="result-year"><%= r.year %></div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <!-- Sample result cards -->
    <div class="results-grid">
      <% const sampleResults = [
        { name: 'Rahul Sharma', exam: 'JEE Advanced', rank: 'AIR 142', year: '2024' },
        { name: 'Priya Singh', exam: 'NEET UG', score: '715/720', year: '2024' },
        { name: 'Amit Verma', exam: 'JEE Mains', percentile: '99.8', year: '2024' },
        { name: 'Sneha Patel', exam: 'Board Exam', rank: 'State Topper', year: '2024' },
        { name: 'Rohan Gupta', exam: 'JEE Advanced', rank: 'AIR 287', year: '2023' },
        { name: 'Ananya Roy', exam: 'NEET UG', score: '710/720', year: '2023' }
      ] %>
      <% sampleResults.forEach((r, i) => { %>
      <div class="result-card" data-aos="zoom-in" data-aos-delay="<%= i * 80 %>">
        <div class="result-rank-badge"><%= r.rank || r.score || r.percentile + '%ile' %></div>
        <img src="/img/default-student.png" alt="<%= r.name %>" class="result-photo" loading="lazy">
        <div class="result-info">
          <h4><%= r.name %></h4>
          <p class="result-exam"><%= r.exam %></p>
          <% if (r.score) { %><p class="result-score"><i class="fas fa-star"></i> <%= r.score %></p><% } %>
          <% if (r.percentile) { %><p class="result-percentile"><i class="fas fa-percent"></i> <%= r.percentile %> Percentile</p><% } %>
        </div>
        <div class="result-year"><%= r.year %></div>
      </div>
      <% }) %>
    </div>
    <% } %>
    <div class="section-cta">
      <a href="/results" class="btn btn-primary btn-lg">See All Results <i class="fas fa-trophy"></i></a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     FACULTY SECTION
══════════════════════════════════════════════════════════ -->
<section class="section faculty-section">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">Meet the Experts</div>
      <h2 class="section-title">Our <span class="text-gradient">Faculty</span></h2>
      <p class="section-desc">Learn from the best — experienced educators who are passionate about student success.</p>
    </div>
    <% if (faculties && faculties.length > 0) { %>
    <div class="faculty-grid">
      <% faculties.slice(0,8).forEach((f, i) => { %>
      <div class="faculty-card" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
        <div class="faculty-photo-wrap">
          <img src="<%= f.photo || '/img/default-faculty.png' %>" alt="<%= f.name %>" class="faculty-photo" loading="lazy">
          <div class="faculty-overlay">
            <p><%= f.about?.substring(0,120) || 'Dedicated educator with years of experience in competitive exam preparation.' %>...</p>
          </div>
        </div>
        <div class="faculty-info">
          <h4><%= f.name %></h4>
          <p class="faculty-design"><%= f.designation %></p>
          <span class="faculty-subject"><i class="fas fa-flask"></i> <%= f.subject %></span>
          <span class="faculty-exp"><i class="fas fa-clock"></i> <%= f.experience || 'Expert' %></span>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="faculty-grid">
      <% const sampleFaculty = [
        { name: 'Dr. Rajesh Kumar', designation: 'HOD Physics', subject: 'Physics', exp: '15 Years', qual: 'IIT Delhi' },
        { name: 'Prof. Sunita Sharma', designation: 'Senior Faculty', subject: 'Chemistry', exp: '12 Years', qual: 'IIT Bombay' },
        { name: 'Mr. Arun Malhotra', designation: 'Mathematics Expert', subject: 'Mathematics', exp: '10 Years', qual: 'IIT Kanpur' },
        { name: 'Dr. Priya Gupta', designation: 'Biology Faculty', subject: 'Biology', exp: '8 Years', qual: 'AIIMS Alumni' }
      ] %>
      <% sampleFaculty.forEach((f, i) => { %>
      <div class="faculty-card" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
        <div class="faculty-photo-wrap">
          <img src="/img/default-faculty.png" alt="<%= f.name %>" class="faculty-photo" loading="lazy">
          <div class="faculty-overlay">
            <p>Expert educator from <%= f.qual %> with <%= f.exp %> of teaching experience in competitive exams.</p>
          </div>
        </div>
        <div class="faculty-info">
          <h4><%= f.name %></h4>
          <p class="faculty-design"><%= f.designation %></p>
          <span class="faculty-subject"><i class="fas fa-flask"></i> <%= f.subject %></span>
          <span class="faculty-exp"><i class="fas fa-clock"></i> <%= f.exp %></span>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
    <div class="section-cta">
      <a href="/faculty" class="btn btn-primary btn-lg">Meet All Faculty <i class="fas fa-users"></i></a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     TESTIMONIALS
══════════════════════════════════════════════════════════ -->
<section class="section testimonials-section">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">Success Stories</div>
      <h2 class="section-title">What Our <span class="text-gradient">Students Say</span></h2>
      <p class="section-desc">Real stories from real achievers who trusted Garud Classes.</p>
    </div>
    <div class="testimonials-slider" id="testimonialSlider">
      <div class="testimonials-track" id="testimonialTrack">
        <% const testimonials = [
          { name: 'Rahul Sharma', exam: 'IIT Bombay (AIR 142)', text: "Garud Classes transformed my preparation completely. The faculty here is exceptionally skilled and the study material is world-class. I couldn't have cracked JEE without them.", stars: 5 },
          { name: 'Priya Singh', exam: 'AIIMS Delhi (NEET 715/720)', text: "The Biology faculty here is the best I've ever seen. Their teaching methodology, regular tests, and personal attention to each student is what makes Garud Classes special.", stars: 5 },
          { name: 'Sneha Patel', exam: '12th Board State Topper', text: "I scored 98.8% in boards and the credit goes entirely to the Garud Classes team. The faculty motivated me every single day and the mock tests were incredibly helpful.", stars: 5 },
          { name: 'Amit Verma', exam: 'IIT Roorkee (AIR 312)', text: "Two years at Garud Classes were the best investment of my life. The structured approach, doubt-clearing sessions, and mentoring helped me grow beyond my expectations.", stars: 5 },
          { name: 'Ananya Roy', exam: 'NEET UG 710/720', text: "From day one, the faculty at Garud Classes made sure I understood every concept deeply. Their dedication and commitment to student success is unmatched.", stars: 5 },
          { name: 'Karan Mishra', exam: 'NTSE Scholar + IIT Delhi', text: "I joined Garud Classes in class 8 for foundation and it became the foundation of my success. The nurturing environment helped me crack both NTSE and JEE Advanced.", stars: 5 }
        ] %>
        <% testimonials.forEach(t => { %>
        <div class="testimonial-card">
          <div class="testimonial-stars">
            <% for(let i=0;i<t.stars;i++) { %><i class="fas fa-star"></i><% } %>
          </div>
          <p class="testimonial-text">"<%= t.text %>"</p>
          <div class="testimonial-author">
            <div class="author-avatar"><%= t.name.charAt(0) %></div>
            <div>
              <strong><%= t.name %></strong>
              <span><%= t.exam %></span>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <div class="slider-controls">
        <button class="slider-btn" id="prevBtn"><i class="fas fa-chevron-left"></i></button>
        <div class="slider-dots" id="sliderDots"></div>
        <button class="slider-btn" id="nextBtn"><i class="fas fa-chevron-right"></i></button>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     LATEST BLOG
══════════════════════════════════════════════════════════ -->
<% if (blogs && blogs.length > 0) { %>
<section class="section blog-section">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">Latest Updates</div>
      <h2 class="section-title">From Our <span class="text-gradient">Blog</span></h2>
      <p class="section-desc">Study tips, exam strategies, and important updates from the Garud Classes team.</p>
    </div>
    <div class="blog-grid">
      <% blogs.forEach((b, i) => { %>
      <div class="blog-card" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
        <div class="blog-img">
          <img src="<%= b.image || '/img/blog-default.jpg' %>" alt="<%= b.title %>" loading="lazy">
          <span class="blog-cat"><%= b.category %></span>
        </div>
        <div class="blog-body">
          <div class="blog-meta"><i class="fas fa-calendar"></i> <%= b.publishedAt?.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %></div>
          <h3><a href="/blog/<%= b.slug %>"><%= b.title %></a></h3>
          <p><%= b.excerpt || b.content?.substring(0,120) + '...' %></p>
          <a href="/blog/<%= b.slug %>" class="read-more">Read More <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
      <% }) %>
    </div>
