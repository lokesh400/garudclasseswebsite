<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Careers at Garud Classes | Recruitment Openings</title>
  <meta name="description" content="Explore latest recruitment openings at Garud Classes. Apply for teaching and non-teaching roles in Palwal and nearby locations." />
  <meta name="keywords" content="Garud Classes careers, Garud Classes recruitment, teaching jobs Palwal, coaching institute jobs" />
  <link rel="canonical" href="https://www.garudclasses.com/recruitments" />
  <meta name="robots" content="index,follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --ink: #0f172a;
      --surface: #f8fafc;
      --primary: #0f766e;
      --accent: #f59e0b;
    }

    body {
      font-family: "Manrope", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 0% 0%, rgba(15, 118, 110, 0.18), transparent 45%),
        radial-gradient(circle at 100% 100%, rgba(245, 158, 11, 0.16), transparent 40%),
        var(--surface);
      min-height: 100vh;
    }

    h1, h2, h3 {
      font-family: "Sora", sans-serif;
      letter-spacing: -0.02em;
    }

    .job-card {
      transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
    }

    .job-card:hover {
      transform: translateY(-4px);
      border-color: rgba(15, 118, 110, 0.28);
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.11);
    }

    .fade-up {
      animation: fadeUp 0.55s ease forwards;
      opacity: 0;
      transform: translateY(14px);
    }

    @keyframes fadeUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>
<body>
  <section class="relative overflow-hidden px-4 pt-10 pb-16">
    <div class="absolute -top-28 -right-24 w-72 h-72 rounded-full bg-teal-400/20 blur-3xl"></div>
    <div class="absolute -bottom-16 -left-20 w-72 h-72 rounded-full bg-amber-400/20 blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto bg-white/80 backdrop-blur-sm rounded-3xl border border-slate-200/70 p-7 md:p-10 shadow-xl">
      <span class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-teal-700 font-bold">
        Career Portal
      </span>
      <h1 class="text-3xl md:text-5xl font-extrabold mt-4 leading-tight">Build Your Next Chapter With Garud Classes</h1>
      <p class="mt-4 text-slate-600 text-base md:text-lg max-w-2xl">
        Browse active openings, read clear role expectations, and submit your application in minutes.
      </p>

      <div class="mt-6 inline-flex items-center gap-3 px-4 py-2 rounded-full bg-teal-50 text-teal-800 text-sm font-semibold">
        <span class="h-2.5 w-2.5 rounded-full bg-teal-600"></span>
        <span> <%= recruitments.length %> Open Position<%= recruitments.length === 1 ? '' : 's' %></span>
      </div>
    </div>
  </section>

  <main class="max-w-6xl mx-auto px-4 pb-14">
    <% if (!recruitments.length) { %>
      <div class="bg-white rounded-2xl shadow-lg border border-slate-200 p-10 text-center">
        <h2 class="text-2xl font-bold">No Openings At The Moment</h2>
        <p class="text-slate-600 mt-2">Please check back soon. New roles are posted regularly.</p>
      </div>
    <% } %>

    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">
      <% recruitments.forEach((job) => { %>
        <article class="job-card fade-up bg-white rounded-2xl border border-slate-200 p-6">
          <div class="flex items-center justify-between gap-3">
            <span class="text-xs font-bold uppercase tracking-[0.15em] text-teal-700"><%= job.department || 'General' %></span>
            <span class="text-xs px-2 py-1 rounded-full bg-slate-100 text-slate-700"><%= job.employmentType || 'Full-time' %></span>
          </div>

          <h2 class="text-xl font-bold mt-4 leading-snug"><%= job.title %></h2>
          <p class="text-sm text-slate-600 mt-2"><%= job.location %></p>

          <% if (job.lastDateToApply) { %>
            <p class="text-sm text-slate-500 mt-2">Apply by <span class="font-semibold text-slate-700"><%= new Date(job.lastDateToApply).toLocaleDateString() %></span></p>
          <% } %>

          <p class="text-sm text-slate-700 mt-4 min-h-[72px]">
            <%= job.description && job.description.length > 150 ? `${job.description.slice(0, 150)}...` : (job.description || '') %>
          </p>

          <div class="mt-5 flex gap-3">
            <a href="/recruitments/<%= job._id %>" class="px-4 py-2 rounded-lg border border-slate-300 text-sm font-semibold hover:bg-slate-50">View Details</a>
            <a href="/recruitments/<%= job._id %>/apply" class="px-4 py-2 rounded-lg bg-teal-700 text-white text-sm font-semibold hover:bg-teal-800">Apply</a>
          </div>
        </article>
      <% }) %>
    </div>
  </main>
</body>
</html>
